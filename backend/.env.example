# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/skidoo2026

# JWT
JWT_SECRET=replace-with-long-random-string-min-64-chars
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS + invite links)
FRONTEND_URL=https://skidoo.murphdunks.com

# College Football Data API
# Get free key at https://collegefootballdata.com/key
CFBD_API_KEY=your-cfbd-api-key

# Email — Gmail App Password recommended
# Generate at: Google Account > Security > App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM_NAME=68 Ski-Doo
EMAIL_FROM_ADDRESS=your@gmail.com

# AWS S3 (for profile photo uploads — optional, can skip initially)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=skidoo-profile-photos

# Season config
CURRENT_SEASON=2026
